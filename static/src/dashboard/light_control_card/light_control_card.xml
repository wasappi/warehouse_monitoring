<templates xml:space="preserve">
    <t t-name="warehouse_monitoring.light_control_card">
        <div class="w-100 bg-view border rounded shadow-sm px-3 py-3 py-sm-2 d-flex align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa fa-lightbulb-o text-warning" aria-hidden="true"/>
                    <span class="small fw-semibold">
                        <t t-esc="props.label"/>
                    </span>
                </div>
                <div class="form-check form-switch m-0">
                    <input
                        class="form-check-input"
                        type="checkbox"
                        role="switch"
                        t-att-checked="props.isOn"
                        t-att-disabled="props.disabled || props.isBusy"
                        t-on-change="props.onToggle"
                    />
                </div>
        </div>
    </t>
</templates>